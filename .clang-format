BasedOnStyle: Google
ColumnLimit: 120
IndentWidth: 2
BinPackArguments: false
BinPackParameters: false         # Keeps parameters on one line unless they exceed ColumnLimit
# Modern clang-format 22 block-formatting options:
AlignAfterOpenBracket: false     # Uses ContinuationIndentWidth instead of aligning to the '(' position
BreakAfterOpenBracketFunction: true
BreakBeforeCloseBracketFunction: true
